{
  "title": "Self-Healing Shadow \u2013 SRE Copilot Dashboard",
  "description": "Autonomous SRE Agent monitoring: target service health, three-agent pipeline traces, Bedrock LLM observability, MCP tool calls, and live incident postmortem.",
  "layout_type": "ordered",
  "notify_list": [],
  "template_variables": [
    {
      "name": "env",
      "default": "hackathon-irvan",
      "available_values": [
        "hackathon-irvan"
      ]
    },
    {
      "name": "service",
      "default": "auth-service",
      "available_values": [
        "auth-service"
      ]
    },
    {
      "name": "agent_service",
      "default": "sre-agent-ecs",
      "available_values": [
        "sre-agent-ecs"
      ]
    }
  ],
  "widgets": [
    {
      "id": 1,
      "definition": {
        "type": "note",
        "content": "# \ud83e\udd16 Self-Healing Shadow \u2014 Autonomous SRE Copilot\n\n**Scope:** `$service` \u00b7 **Agent:** `$agent_service` \u00b7 **Env:** `$env`\n\nDatadog alert \u2192 SRE Agent (Triage \u2192 Investigate \u2192 Remediate) \u2192 Slack runbook. Every Bedrock call and MCP tool invocation is traced via `ddtrace`.",
        "background_color": "vivid_blue",
        "font_size": "14",
        "text_align": "left",
        "vertical_align": "center",
        "show_tick": false,
        "tick_pos": "50%",
        "tick_edge": "left",
        "has_padding": true
      },
      "layout": {
        "x": 0,
        "y": 0,
        "width": 12,
        "height": 2
      }
    },
    {
      "id": 2,
      "definition": {
        "type": "query_value",
        "title": "HTTP 5xx Error Rate",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1 / query2 * 100"
              }
            ],
            "queries": [
              {
                "name": "query1",
                "data_source": "metrics",
                "query": "sum:trace.servlet.request.errors{env:$env,service:$service}.as_rate()"
              },
              {
                "name": "query2",
                "data_source": "metrics",
                "query": "sum:trace.servlet.request.hits{env:$env,service:$service}.as_rate()"
              }
            ],
            "response_format": "scalar",
            "conditional_formats": [
              {
                "comparator": ">",
                "value": 5,
                "palette": "white_on_red"
              },
              {
                "comparator": "<=",
                "value": 1,
                "palette": "white_on_green"
              },
              {
                "comparator": "<=",
                "value": 5,
                "palette": "white_on_yellow"
              }
            ]
          }
        ],
        "autoscale": true,
        "precision": 2,
        "custom_unit": "%",
        "text_align": "center"
      },
      "layout": {
        "x": 0,
        "y": 2,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 3,
      "definition": {
        "type": "query_value",
        "title": "p99 Request Latency",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "name": "query1",
                "data_source": "metrics",
                "query": "p99:trace.servlet.request{env:$env,service:$service}"
              }
            ],
            "response_format": "scalar",
            "conditional_formats": [
              {
                "comparator": ">",
                "value": 2000,
                "palette": "white_on_red"
              },
              {
                "comparator": "<=",
                "value": 500,
                "palette": "white_on_green"
              }
            ]
          }
        ],
        "autoscale": true,
        "precision": 1,
        "custom_unit": "ms",
        "text_align": "center"
      },
      "layout": {
        "x": 3,
        "y": 2,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 4,
      "definition": {
        "type": "query_value",
        "title": "Pipeline Runs (/webhook)",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "name": "query1",
                "data_source": "metrics",
                "query": "sum:trace.fastapi.request.hits{env:$env}.as_count()"
              }
            ],
            "response_format": "scalar",
            "conditional_formats": [
              {
                "comparator": ">=",
                "value": 1,
                "palette": "white_on_blue"
              }
            ]
          }
        ],
        "autoscale": true,
        "precision": 0,
        "custom_unit": "runs",
        "text_align": "center"
      },
      "layout": {
        "x": 6,
        "y": 2,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 5,
      "definition": {
        "type": "query_value",
        "title": "DB Timeout Errors (Chaos Signal)",
        "title_size": "16",
        "title_align": "left",
        "requests": [
          {
            "formulas": [
              {
                "formula": "query1"
              }
            ],
            "queries": [
              {
                "name": "query1",
                "data_source": "metrics",
                "query": "sum:auth.errors.database_timeout{env:$env,service:$service}.as_count()"
              }
            ],
            "response_format": "scalar",
            "conditional_formats": [
              {
                "comparator": ">",
                "value": 0,
                "palette": "white_on_red"
              },
              {
                "comparator": "<=",
                "value": 0,
                "palette": "white_on_green"
              }
            ]
          }
        ],
        "autoscale": true,
        "precision": 0,
        "custom_unit": "errors",
        "text_align": "center"
      },
      "layout": {
        "x": 9,
        "y": 2,
        "width": 3,
        "height": 2
      }
    },
    {
      "id": 6,
      "definition": {
        "type": "note",
        "content": "### \ud83c\udfaf Target Service Health \u2014 `$service`\nHTTP errors, latency, throughput, and chaos-mode database timeout counter.",
        "background_color": "gray",
        "font_size": "14",
        "text_align": "left",
        "vertical_align": "center",
        "show_tick": false,
        "tick_pos": "50%",
        "tick_edge": "left",
        "has_padding": true
      },
      "layout": {
        "x": 0,
        "y": 4,
        "width": 12,
        "height": 1
      }
    },
    {
      "id": 7,
      "definition": {
        "type": "timeseries",
        "title": "HTTP 5xx Error Rate & p99 Latency",
        "title_size": "16",
        "title_align": "left",
        "show_legend": true,
        "legend_layout": "horizontal",
        "legend_columns": [
          "avg",
          "min",
          "max",
          "value",
          "sum"
        ],
        "requests": [
          {
            "formulas": [
              {
                "alias": "5xx Error Rate (%)",
                "formula": "query_errors / query_hits * 100"
              }
            ],
            "queries": [
              {
                "name": "query_errors",
                "data_source": "metrics",
                "query": "sum:trace.servlet.request.errors{env:$env,service:$service}.as_rate()"
              },
              {
                "name": "query_hits",
                "data_source": "metrics",
                "query": "sum:trace.servlet.request.hits{env:$env,service:$service}.as_rate()"
              }
            ],
            "response_format": "timeseries",
            "style": {
              "palette": "warm",
              "line_type": "solid",
              "line_width": "thick"
            },
            "display_type": "line"
          },
          {
            "formulas": [
              {
                "alias": "p99 Latency (ms)",
                "formula": "query_latency"
              }
            ],
            "queries": [
              {
                "name": "query_latency",
                "data_source": "metrics",
                "query": "p99:trace.servlet.request{env:$env,service:$service}"
              }
            ],
            "response_format": "timeseries",
            "style": {
              "palette": "cool",
              "line_type": "solid",
              "line_width": "normal"
            },
            "display_type": "line",
            "on_right_yaxis": true
          }
        ],
        "yaxis": {
          "include_zero": true,
          "scale": "linear",
          "label": "Error Rate (%)",
          "min": "auto",
          "max": "auto"
        },
        "right_yaxis": {
          "include_zero": true,
          "scale": "linear",
          "label": "Latency (ms)"
        },
        "markers": [
          {
            "value": "y = 5",
            "display_type": "error dashed",
            "label": "5% error threshold"
          }
        ],
        "time": {
          "live_span": "1h"
        }
      },
      "layout": {
        "x": 0,
        "y": 5,
        "width": 8,
        "height": 5
      }
    },
